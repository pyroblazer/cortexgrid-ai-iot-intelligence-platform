{
  "name": "@cortexgrid/iot-simulator",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
