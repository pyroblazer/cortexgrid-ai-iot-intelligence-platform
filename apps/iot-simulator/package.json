  "dependencies": {
    "mqtt": "^5.3.0",
    "dotenv": "^16.4.0",
    "winston": "^3.11.0",
    "zod": "^3.22.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.8",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.0",
    "@cortexgrid/eslint-config": "workspace:*"
  }
}
