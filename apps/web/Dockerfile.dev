# ─── Development Dockerfile for CortexGrid Web ────────────────────────────
FROM node:20-alpine

RUN corepack enable && corepack prepare pnpm@9.12.0 --activate

WORKDIR /app

COPY package.json pnpm-lock.yaml* ./

RUN pnpm install --frozen-lockfile

COPY . .

EXPOSE 3000 9229

ENV NODE_ENV=development

CMD ["pnpm", "run", "dev"]
