        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(http_requests_total{job=\"cortexgrid-api\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"cortexgrid-api\"}[5m]))",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ]
