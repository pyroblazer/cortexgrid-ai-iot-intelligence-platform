{
  "info": {
    "name": "CortexGrid API",
    "description": "Complete API test collection for the CortexGrid AI-IoT Intelligence Platform.\n\nCovers authentication, device management, telemetry ingestion, alerts, AI features, and billing.\n\nVariables:\n- base_url: API base URL\n- token: JWT access token (auto-set on login)\n- org_id: Organization ID (auto-set on register/login)\n- device_id: Device ID (auto-set on device creation)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3001" },
    { "key": "token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "org_id", "value": "" },
    { "key": "device_id", "value": "" },
    { "key": "alert_id", "value": "" },
    { "key": "rule_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Authentication endpoints for user registration, login, token refresh, and profile retrieval.",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has success and data wrapper', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.eql(true);",
                  "    pm.expect(json).to.have.property('data');",
                  "});",
                  "",
                  "pm.test('Response has required fields', function () {",
                  "    const json = pm.response.json();",
                  "    const data = json.data;",
                  "    pm.expect(data).to.have.property('user');",
                  "    pm.expect(data).to.have.property('organization');",
                  "    pm.expect(data).to.have.property('accessToken');",
                  "    pm.expect(data).to.have.property('refreshToken');",
                  "    pm.expect(data.user).to.have.property('id');",
                  "    pm.expect(data.user).to.have.property('email');",
                  "});",
                  "",
                  "pm.test('User email matches request', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data.user.email).to.eql('testuser@cortexgrid.io');",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    const data = json.data;",
                  "    pm.environment.set('token', data.accessToken);",
                  "    pm.environment.set('refresh_token', data.refreshToken);",
                  "    pm.environment.set('org_id', data.organization.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"testuser@cortexgrid.io\",\n    \"password\": \"SecureP@ss123\",\n    \"firstName\": \"Test\",\n    \"lastName\": \"User\",\n    \"organizationName\": \"Test Organization\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has tokens', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data).to.have.property('accessToken');",
                  "    pm.expect(json.data).to.have.property('refreshToken');",
                  "    pm.expect(json.data.accessToken).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('Response has user object', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data).to.have.property('user');",
                  "    pm.expect(json.data.user).to.have.property('id');",
                  "    pm.expect(json.data.user).to.have.property('email');",
                  "    pm.expect(json.data.user).to.have.property('memberships');",
                  "    pm.expect(json.data.user.memberships).to.be.an('array');",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.environment.set('token', json.data.accessToken);",
                  "    pm.environment.set('refresh_token', json.data.refreshToken);",
                  "    if (json.data.user.memberships && json.data.user.memberships.length > 0) {",
                  "        pm.environment.set('org_id', json.data.user.memberships[0].organizationId);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"testuser@cortexgrid.io\",\n    \"password\": \"SecureP@ss123\"\n}"
            }
          },
          "response": []
        },
