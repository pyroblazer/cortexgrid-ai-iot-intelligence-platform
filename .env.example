# CortexGrid Environment Variables
# Copy this to .env and fill in the values

# === Database ===
DATABASE_URL=postgresql://cortexgrid:cortexgrid@localhost:5432/cortexgrid?schema=public

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379

# === MQTT ===
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=cortexgrid
MQTT_PASSWORD=cortexgrid

# === Auth ===
JWT_ACCESS_SECRET=your-super-secret-access-token-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# === Stripe ===
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_pro_monthly
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_monthly

# === AI ===
OLLAMA_BASE_URL=http://localhost:11434
HUGGINGFACE_API_KEY=hf_your_key_optional

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# === Observability ===
PROMETHEUS_PORT=9090
GRAFANA_PORT=3002
